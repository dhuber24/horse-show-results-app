# Horse Show Results App - Environment Variables Template
# Copy this file to .env and fill in your local values
# NEVER commit the .env file to version control

# ============================================================
# BACKEND CONFIGURATION
# ============================================================

# Server
BACKEND_HOST=localhost
BACKEND_PORT=8000
DEBUG=True

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# PostgreSQL Connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/horse_show_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=horse_show_db

# Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_TIMEOUT=30000

# App Configuration
NEXT_PUBLIC_APP_NAME=Horse Show Results
NEXT_PUBLIC_APP_VERSION=0.1.0

# Environment
NODE_ENV=development
NEXT_DEBUG=false

# ============================================================
# AUTHENTICATION
# ============================================================

# JWT Settings
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

# Password
PASSWORD_MIN_LENGTH=8

# ============================================================
# LOGGING
# ============================================================

LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=json

# ============================================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================================

# Email (for future notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM_EMAIL=noreply@horseshowresults.com

# File Storage (for future photo uploads)
STORAGE_TYPE=local
STORAGE_PATH=./storage
# Or S3:
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_S3_BUCKET=your-bucket

# ============================================================
# DEVELOPMENT ONLY
# ============================================================

# Enable test data seeding on startup
SEED_TEST_DATA=False

# Drop and recreate database on startup (DANGER!)
DROP_DB_ON_STARTUP=False

# Enable API documentation
ENABLE_API_DOCS=True
